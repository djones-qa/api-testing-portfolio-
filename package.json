{
  "name": "api-testing-portfolio",
  "version": "1.0.0",
  "description": "REST API test suite using Playwright API testing against Restful Booker",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:crud": "playwright test --grep @crud",
    "test:auth": "playwright test --grep @auth",
    "test:schema": "playwright test --grep @schema",
    "test:data-driven": "playwright test --grep @data-driven",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "ajv": "^8.13.0"
  }
}
